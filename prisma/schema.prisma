// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  BORROWER
  ADMIN
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  phone String
  email String
  role  Role
}

model Item {
  id          Int     @id @default(autoincrement())
  ownerId     Int
  title       String
  description String
  available   Boolean @default(true)
}

model Booking {
  id         Int           @id @default(autoincrement())
  itemId     Int
  borrowerId Int
  status     BookingStatus @default(PENDING)
}












